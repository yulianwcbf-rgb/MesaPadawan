# Optional: enable the shared Supabase backend (login + data shared by everyone).
# Copy this file to ".env" and fill in the values from your Supabase project
# (Project Settings → API). These are public, safe-to-ship values.
#
# If you leave these unset, the app runs with the browser-local backend
# (data stays in each person's browser).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Only used by the browser-local fallback: the seeded admin account.
# VITE_ADMIN_EMAIL=admin@mesa.local
# VITE_ADMIN_PASSWORD=admin123
